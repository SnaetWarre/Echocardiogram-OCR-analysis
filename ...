export SWEEP_DICOM_ROOT="/path/to/dicoms_or_folder"
export GLM_OCR_RUNNER=mamba GLM_OCR_ENV=glm_ocr
export SURYA_RUNNER=mamba SURYA_ENV=surya

ROOT="/home/warre/Documents/howest/Semester_5/Stage/StageOpdracht/Master"
STAMP="$(date -u +%Y%m%dT%H%M%SZ)"
OUT_PARENT="${ROOT}/artifacts/ocr_redesign"
mkdir -p "$OUT_PARENT"

for engine in glm-ocr tesseract surya; do
  safe="${engine//-/_}"
  mamba run -n DL python -m app.tools.sweep_preprocessing_headless \
    "$SWEEP_DICOM_ROOT" \
    --recursive \
    --config-set order_matrix_plan \
    --engine "$engine" \
    --split validation \
    --output-dir "${OUT_PARENT}/plan_order_matrix_${STAMP}_${safe}" \
    --resume-configs \
    --skip-existing
done